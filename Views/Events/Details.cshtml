@model BookingSystem.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<h1>Details</h1>

<div>
    <h4>Event</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Event Name</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.EventName)</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Description)</dd>

        <dt class="col-sm-2">Date & Time</dt>
        <dd class="col-sm-10">@Model.EventDate.ToShortDateString() at @Model.EventTime.ToString(@"hh\:mm")</dd>

        <dt class="col-sm-2">Event Image</dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" style="max-width:500px;" />
            }
            else
            {
                <span class="text-muted">No image uploaded.</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.EventID" class="btn btn-warning">Edit</a> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>