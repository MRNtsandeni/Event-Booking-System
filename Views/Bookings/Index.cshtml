
    @model IEnumerable<BookingSystem.Models.BookingSummary>


<form method="get" asp-action="Index" class="row g-3 mb-4">
    <div class="col-auto">
        <input type="text" name="searchString" class="form-control" placeholder="Event Name/ID" />
    </div>

    <div class="col-auto">
        <select name="eventTypeId" asp-items="ViewBag.EventTypeID" class="form-control">
            <option value="">-- All Event Types --</option>
        </select>
    </div>

    <div class="col-auto">
        <input type="date" name="startDate" class="form-control" title="Start Date" />
    </div>
    <div class="col-auto">
        <input type="date" name="endDate" class="form-control" title="End Date" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>
</form>



@{
    ViewData["Title"] = "Booking Summary";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Error!</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<h1>Booking Management</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Booking</a>
</p>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group">
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Booking ID</th>
            <th>Event Name</th>
            <th>Venue Name</th>
            <th>Event Type</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.BookingID</td>
                <td>@item.EventName</td>
                <td>@item.VenueName</td>
                <td>@item.EventTypeName</td>

                <td>@item.StartDate.ToString("g")</td>
                <td>@item.EndDate.ToString("g")</td>

                <td>@item.BookingStatus</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.BookingID">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BookingID">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BookingID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

