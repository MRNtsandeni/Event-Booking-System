@model BookingSystem.Models.Booking

<h1>Booking Details</h1>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Venue</dt>
        <dd class="col-sm-10">@Model.Venue?.VenueName</dd>

        <dt class="col-sm-2">Event</dt>
        <dd class="col-sm-10">@Model.Event?.EventName</dd>

        <dt class="col-sm-2">Event Type</dt>
        <dd class="col-sm-10">@Model.EventType?.Name</dd>

        <dt class="col-sm-2">Start Date</dt>
        <dd class="col-sm-10">@Model.StartDate.ToString("g")</dd>


        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.BookingStatus</dd>
    </dl>
</div>