@model BookingSystem.Models.Venue

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Error!</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<h1>Create Venue</h1>
<form asp-action="Create" enctype="multipart/form-data">
    <div class="form-group">
        <label asp-for="VenueName"></label>
        <input asp-for="VenueName" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Location"></label>
        <input asp-for="Location" class="form-control" />
    </div>

    <div class="form-group">
    <label asp-for="Capacity" class="control-label"></label>
    <input asp-for="Capacity" class="form-control" type="number" />
    <span asp-validation-for="Capacity" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Upload Image</label>
        <input type="file" name="VenueImage" class="form-control" />
    </div>
    <input type="submit" value="Save" class="btn btn-success mt-2" />
</form>